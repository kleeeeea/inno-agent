{
	"name": "inno-agent",
	"version": "0.2.0",
	"description": "Personal learning agent built on PI SDK with three-layer memory system",
	"type": "module",
	"bin": {
		"inno": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/cli.js",
		"server": "node dist/server.js",
		"web:dev": "npm --workspace inno-agent-web run dev",
		"web:build": "npm --workspace inno-agent-web run build"
	},
	"dependencies": {
		"@earendil-works/pi-ai": "^0.74.0",
		"@earendil-works/pi-coding-agent": "^0.74.0",
		"@juicesharp/rpiv-ask-user-question": "^1.12.0",
		"@llamaindex/liteparse": "^1.3.0",
		"@larksuiteoapi/node-sdk": "^1.63.1",
		"@types/ws": "^8.18.1",
		"axios": "^1.16.1",
		"cron-parser": "^5.5.0",
		"node-pty": "^1.0.0",
		"pi-sandbox": "^0.4.3",
		"pi-subagents": "^0.25.0",
		"typebox": "^1.1.24",
		"undici": "^7.19.1",
		"ws": "^8.21.0"
	},
	"engines": {
		"node": ">=20.6.0"
	}
}
