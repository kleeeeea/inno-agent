{
	"name": "inno-agent",
	"version": "0.4.3",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/inno-agent",
		"apps/inno-agent/web"
	],
	"main": "electron/main.js",
	"scripts": {
		"build": "npm --workspace inno-agent run build && npm --workspace inno-agent-web run build",
		"start": "npm --workspace inno-agent run start --",
		"sandbox": "npm --workspace inno-agent run start -- --sandbox",
		"server": "npm --workspace inno-agent run server --",
		"server:sandbox": "npm --workspace inno-agent run server -- --sandbox",
		"hihiweb:dev": "npm --workspace inno-agent-web run dev",
		"dev:server": "npm --workspace inno-agent run server --",
		"restart": "bash restart-dev.sh",
		"restart:fast": "bash restart-dev.sh --skip-build",
		"electron": "electron .",
		"electron:build": "npm run build && electron-builder --mac",
		"electron:build:win": "npm run build && electron-builder --win"
	},
	"engines": {
		"node": ">=20.6.0"
	},
	"build": {
		"appId": "com.inno.agent",
		"productName": "Inno Agent",
		"afterPack": "scripts/after-pack.cjs",
		"directories": {
			"output": "dist-electron"
		},
		"files": [
			"electron/**/*",
			"apps/inno-agent/dist/**/*",
			"apps/inno-agent/web/dist/**/*",
			"apps/inno-agent/presets/**/*",
			"apps/inno-agent/scripts/**/*",
			"node_modules/**/*",
			"!node_modules/.cache/**/*"
		],
		"asarUnpack": [
			"**/node_modules/node-pty/**/*",
			"**/node_modules/@homebridge/**/*",
			"apps/inno-agent/presets/**/*",
			"apps/inno-agent/scripts/**/*"
		],
		"mac": {
			"icon": "build/icon.icns",
			"target": [
				{
					"target": "dmg",
					"arch": [
						"arm64"
					]
				}
			],
			"category": "public.app-category.productivity",
			"darkModeSupport": true
		},
		"dmg": {
			"title": "Inno Agent"
		},
		"win": {
			"icon": "build/icon.png",
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				},
				{
					"target": "msi",
					"arch": [
						"x64"
					]
				}
			]
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"perMachine": false
		},
		"msi": {
			"oneClick": false,
			"perMachine": false
		}
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.0.0-beta.14",
		"@tailwindcss/vite": "^4.1.7",
		"@types/node": "^24.3.0",
		"concurrently": "^9.2.1",
		"electron": "^42.3.0",
		"electron-builder": "^26.8.1",
		"shx": "^0.4.0",
		"tailwindcss": "^4.1.7",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vite": "^6.3.5",
		"vitest": "^3.2.4"
	},
	"overrides": {
		"@larksuiteoapi/node-sdk": {
			"axios": "^1.16.1"
		},
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		},
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	}
}
